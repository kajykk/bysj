{
  "id": {{ panel.id }},
  "type": "bargauge",
  "title": {{ panel.title | tojson }},
  "gridPos": {
    "x": {{ panel.gridPos.x }},
    "y": {{ panel.gridPos.y }},
    "w": {{ panel.gridPos.w }},
    "h": {{ panel.gridPos.h }}
  },
  "datasource": {
    "type": "simpod-json-datasource",
    "uid": "${DS_OBSERVABILITY_API}"
  },
  "targets": [
    {
      "refId": "A",
      "datasource": {
        "type": "simpod-json-datasource",
        "uid": "${DS_OBSERVABILITY_API}"
      },
      "payload": {
        "metric": {{ panel.metric | tojson }},
        "params": {{ panel.params | tojson }}
      }
    }
  ],
  "fieldConfig": {
    "defaults": {
      "unit": {{ panel.fieldConfig.unit | tojson }}
      {%- if panel.fieldConfig.min is defined %},
      "min": {{ panel.fieldConfig.min }},
      "max": {{ panel.fieldConfig.max }}
      {%- endif %}
      {%- if panel.fieldConfig.thresholds is defined %},
      "thresholds": {
        "mode": "absolute",
        "steps": {{ panel.fieldConfig.thresholds.steps | tojson }}
      }
      {%- endif %}
    }
  },
  "options": {
    "orientation": "horizontal",
    "displayMode": "gradient",
    "showUnfilled": true,
    "valueMode": "color"
  }
}
