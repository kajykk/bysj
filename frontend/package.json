{
  "name": "depression-warning-system-frontend",
  "version": "3.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json --pretty false",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright test --reporter=line && python ../scripts/update-test-overview.py",
    "test:e2e:doctor": "npx playwright install --dry-run && echo Playwright browsers OK",
    "postinstall": "playwright install chromium",
    "lint": "eslint . --ext .vue,.ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .vue,.ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lighthouse": "lighthouse http://localhost:5173 --output=html --output-path=./lighthouse-report.html",
    "lighthouse:ci": "lighthouse http://localhost:5173 --output=json --output-path=./lighthouse-report.json --chrome-flags='--headless --no-sandbox'",
    "perf:audit": "npm run build && npm run lighthouse:ci"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@sentry/vue": "^10.50.0",
    "axios": "^1.8.2",
    "dompurify": "^3.4.1",
    "echarts": "^5.5.1",
    "element-plus": "^2.8.4",
    "pinia": "^2.1.7",
    "vue": "^3.5.13",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vitest/coverage-v8": "^4.1.3",
    "@vue/eslint-config-typescript": "^13.0.0",
    "@vue/language-core": "^3.2.7",
    "@vue/test-utils": "^2.4.6",
    "chrome-launcher": "^1.2.1",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.28.0",
    "jsdom": "^29.0.2",
    "lighthouse": "^13.1.0",
    "prettier": "^3.3.3",
    "puppeteer": "^24.42.0",
    "sass": "^1.77.8",
    "terser": "^5.46.2",
    "typescript": "^5.6.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^6.2.6",
    "vite-plugin-compression2": "^2.5.3",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^4.1.3",
    "vue-tsc": "^3.2.7",
    "workbox-window": "^7.3.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  }
}
