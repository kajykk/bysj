# ============================================
# Depression Warning System - 环境配置模板
# ============================================
# 复制此文件为 .env 并填写实际值
# 生产环境必须修改所有安全相关配置
# ============================================

# --- 应用基础配置 ---
APP_NAME="Depression Warning System"
APP_VERSION="3.1.0"
APP_ENV="development"

# --- 数据库配置 ---
# 开发环境: SQLite (默认)
DATABASE_URL="sqlite+aiosqlite:///depression_system.db"
# 生产环境: PostgreSQL (当 APP_ENV=production 时自动切换)
# DATABASE_URL="postgresql+asyncpg://depress_admin:CHANGE_ME_strong_password@postgres:5432/depression_system"

# --- Redis 配置 ---
REDIS_URL="redis://localhost:6379/0"

# --- JWT 安全配置 (必填) ---
# 生成命令: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=""
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# --- 邮件服务配置 ---
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=""

# --- 密码重置链接 ---
PASSWORD_RESET_BASE_URL="http://localhost:5173/reset-password"

# --- CORS 配置 ---
# 生产环境应限制为实际域名
CORS_ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# --- 模型配置 ---
MODEL_DIR="models"

# --- 数据种子 ---
ENABLE_SEED=false

# --- Sentry 错误监控 (可选) ---
# SENTRY_DSN=""
# SENTRY_ENVIRONMENT="development"
# SENTRY_TRACES_SAMPLE_RATE=0.1

# --- v1.37 Grafana Service Account 鉴权 ---
# Grafana Service Account Token (与根 .env 的 GRAFANA_SA_TOKEN 同步)
# 用于 Grafana JSON Datasource 调用后端 /grafana/* 端点时的鉴权
# 留空 (None) 表示禁用 SA 鉴权, 仅允许 Admin User JWT
# 生成示例: python -c "import secrets; print('glsa_' + secrets.token_urlsafe(32))"
GRAFANA_SERVICE_TOKEN=""
