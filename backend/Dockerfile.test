# Test Dockerfile for Depression Warning System Backend
# Usage: docker build -f Dockerfile.test -t dws-test .
#        docker run --rm -v $(pwd):/app dws-test

FROM python:3.12-slim

# Install system dependencies
RUN apt-get update && apt-get install -y \
    gcc \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Install Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Install test dependencies
RUN pip install --no-cache-dir \
    pytest>=9.0.0 \
    pytest-asyncio>=0.25.0 \
    pytest-cov>=6.0.0 \
    httpx>=0.27.0 \
    schemathesis>=4.16.0 \
    hypothesis>=6.152.0

# Set environment variables
ENV APP_ENV=test
ENV DATABASE_URL=sqlite+aiosqlite:///./test.db
ENV JWT_SECRET_KEY=test-secret-key-for-docker-only
ENV PYTHONPATH=/app

# Default command: run tests
CMD ["pytest", "tests/", "-v", "--cov=app", "--cov-report=term-missing"]
