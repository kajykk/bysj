APP_ENV=production
DATABASE_URL=postgresql+asyncpg://depress_admin:CHANGE_ME_strong_password@localhost:5432/depression_system
REDIS_URL=redis://:CHANGE_ME_redis_password@localhost:6379/0

# ============================================
# Docker Compose 所需变量 (docker-compose.yml 引用)
# POSTGRES_PASSWORD / REDIS_PASSWORD 必须与上方 DATABASE_URL/REDIS_URL 中的密码一致
# ============================================
POSTGRES_PASSWORD=CHANGE_ME_strong_password
REDIS_PASSWORD=CHANGE_ME_redis_password

# P2-2: Celery worker 并发数 (默认 2, 按宿主机 CPU 调整)
CELERY_WORKER_CONCURRENCY=2

# ============================================
# 安全警告: 生产环境必须更换此密钥!
# 生成安全密钥: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ============================================
JWT_SECRET_KEY=CHANGE_ME_generate_with_python_secrets_token_urlsafe_32
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
# SEC-P1-002: 生产环境 (APP_ENV=production) 必须使用 https:// 前缀, 否则应用启动失败
PASSWORD_RESET_BASE_URL=http://localhost:5173/reset-password
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=mailer@example.com
SMTP_PASSWORD=change_me
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=no-reply@example.com

# ============================================
# PII 加密密钥 (v1.27, P2-4 密钥轮换)
# 用于 email/phone/emergency_contact 字段透明加密 (Fernet + HKDF 字段级派生)
# 生产环境必须显式配置, 开发环境自动生成并持久化到 backend/.pii_key
# 生成: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ============================================
PII_ENCRYPTION_KEY=

# P2-4: PII 密钥轮换 - 旧密钥列表 (逗号分隔, 仅用于解密回退)
# 轮换流程:
#   1. 将当前 PII_ENCRYPTION_KEY 的值加入此列表
#   2. 设置新的 PII_ENCRYPTION_KEY
#   3. 重启应用 (decrypt_field 自动回退旧密钥解密旧密文)
#   4. 运行 cd backend && python scripts/rotate_pii_keys.py --apply
#   5. 验证后清除此列表 (留空)
# 多个旧密钥用英文逗号分隔, 例如: KEY1_BASE64,KEY2_BASE64
PII_PREVIOUS_KEYS=

MODEL_DIR=./models
VITE_API_BASE_URL=http://localhost:8000/api/v1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- v1.37 Grafana 仪表盘 ---
# Grafana Admin 登录密码 (Grafana 容器启动时使用, GF_SECURITY_ADMIN_PASSWORD)
GRAFANA_ADMIN_PASSWORD=changeme
# Grafana Service Account Token (Grafana 调用后端 /grafana/* 时附加, format: glsa_xxx)
# 创建方法参见 docs/planning/v1.37-grafana-dashboards/11-research-r3.md §3
GRAFANA_SA_TOKEN=
# 后端 .env 同步字段: GRAFANA_SERVICE_TOKEN (与 GRAFANA_SA_TOKEN 相同值)

# --- v1.39 Grafana Alerting 告警渠道 (RISK-2 缓解) ---
# 至少配置 2 个, 避免单点失败 (单渠道失效导致告警静默)
# 参考: infra/grafana/provisioning/alerting/contact-points.yaml

# P0 即时通道 (推荐: PagerDuty / Opsgenie webhook)
# 示例: https://events.pagerduty.com/v2/enqueue
# 空值时 Grafana 自动 disable sre-webhook contact point (RISK-2 行为)
GRAFANA_WEBHOOK_URL=

# P0 存档通道 (SRE 团队邮箱, 多地址用英文逗号分隔)
# 示例: sre-alerts@company.com,oncall@company.com
GRAFANA_SRE_EMAIL=

# P1 协同通道 (Slack Incoming Webhook)
# 创建: https://api.slack.com/messaging/webhooks
# 示例: https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXX
GRAFANA_SLACK_URL=

# P1 Slack 频道 (默认 #sre-alerts)
GRAFANA_SLACK_CHANNEL=#sre-alerts
